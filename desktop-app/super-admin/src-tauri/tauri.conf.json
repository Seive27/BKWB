{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BKWB Super Admin",
  "version": "1.0.0",
  "identifier": "com.bkwb.superadmin",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "BKWB - Super Admin Dashboard",
        "width": 1920,
        "height": 1080,
        "minWidth": 1366,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
